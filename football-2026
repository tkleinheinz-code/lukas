<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Monarchs Playbook – Archbishop Mitty Football</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --black: #0d0d0d;
  --black2: #1a1a1a;
  --black3: #262626;
  --gold: #c8991a;
  --gold-light: #f0c040;
  --gold-pale: #fdf3d0;
  --gold-border: rgba(200,153,26,0.35);
  --surface: #ffffff;
  --surface2: #f5f5f5;
  --text: #111111;
  --text2: #666666;
  --border: rgba(0,0,0,0.12);
}
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f0f0; display: flex; justify-content: center; padding: 2rem 1rem; min-height: 100vh; }
#app { width: 100%; max-width: 680px; }

.header {
  background: var(--black);
  padding: 1.1rem 1.25rem;
  display: flex; align-items: center; gap: 12px;
  border-radius: 12px 12px 0 0;
  border-bottom: 2px solid var(--gold);
}
.header-crest {
  width: 38px; height: 38px; background: var(--gold);
  border-radius: 6px; display: flex; align-items: center; justify-content: center;
  font-size: 20px; color: var(--black); font-weight: 700; flex-shrink: 0;
}
.header h1 { color: #fff; font-size: 17px; font-weight: 500; letter-spacing: 0.01em; }
.header p { color: var(--gold); font-size: 11px; margin-top: 1px; letter-spacing: 0.08em; text-transform: uppercase; }
.sync-dot {
  margin-left: auto; width: 8px; height: 8px; border-radius: 50%;
  background: #555; flex-shrink: 0; transition: background 0.3s;
}
.sync-dot.synced { background: #4caf50; }
.sync-dot.syncing { background: var(--gold); }
.sync-dot.error { background: #e24b4a; }

.nav {
  display: flex; border-bottom: 0.5px solid var(--border);
  background: var(--surface); overflow-x: auto;
}
.nav button {
  flex: 1; padding: 0.85rem 0.5rem; border: none; background: transparent;
  font-size: 13px; font-weight: 500; color: var(--text2);
  cursor: pointer; border-bottom: 2.5px solid transparent;
  transition: color 0.15s, border-color 0.15s;
  white-space: nowrap; display: flex; align-items: center; justify-content: center; gap: 6px;
}
.nav button.active { color: var(--black); border-bottom-color: var(--gold); }
.nav button:hover:not(.active) { color: var(--text); }

.tab { display: none; padding: 1.1rem 1.1rem 1.5rem; background: var(--surface); }
.tab.active { display: block; }
.tab:last-child { border-radius: 0 0 12px 12px; }

.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.section-header h2 { font-size: 15px; font-weight: 500; color: var(--text); }

.btn-gold {
  background: var(--gold); color: var(--black); border: none;
  padding: 8px 16px; border-radius: 8px;
  font-size: 13px; font-weight: 500; cursor: pointer; transition: background 0.15s;
}
.btn-gold:hover { background: var(--gold-light); }
.btn-sm {
  background: transparent; border: 0.5px solid var(--border);
  color: var(--text2); padding: 5px 12px; border-radius: 8px;
  font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 5px;
}
.btn-sm:hover { background: var(--surface2); color: var(--text); }
.btn-icon {
  background: transparent; border: none; color: var(--text2);
  cursor: pointer; padding: 4px; font-size: 16px; line-height: 1;
}
.btn-icon:hover { color: #e24b4a; }

.search-wrap { position: relative; margin-bottom: 12px; }
.search-wrap input {
  width: 100%; padding: 9px 12px 9px 36px;
  border: 0.5px solid var(--border); border-radius: 8px;
  background: var(--surface2); color: var(--text); font-size: 14px;
}
.search-wrap input:focus { outline: none; border-color: var(--gold); }
.search-icon {
  position: absolute; left: 11px; top: 50%; transform: translateY(-50%);
  color: var(--text2); font-size: 16px; pointer-events: none;
}

.add-form {
  background: var(--surface); border: 0.5px solid var(--gold-border);
  border-radius: 12px; padding: 1rem; margin-bottom: 1rem;
}
.add-form h3 { font-size: 13px; font-weight: 500; margin-bottom: 12px; color: var(--text); }
.form-row { margin-bottom: 10px; }
.form-row label { display: block; font-size: 12px; color: var(--text2); margin-bottom: 4px; }
.form-row input, .form-row textarea, .form-row select {
  width: 100%; font-size: 14px; padding: 8px 10px;
  border: 0.5px solid var(--border); border-radius: 8px;
  background: var(--surface2); color: var(--text); font-family: inherit;
}
.form-row textarea { resize: vertical; min-height: 80px; }

.notes-list { display: flex; flex-direction: column; gap: 8px; }
.note-card {
  background: var(--surface); border: 0.5px solid var(--border);
  border-radius: 12px; padding: 0.9rem 1rem;
  border-left: 3px solid transparent;
}
.note-card.practice { border-left-color: var(--gold); }
.note-card.film { border-left-color: #378add; }
.note-card.strategy { border-left-color: #1d9e75; }
.note-card-top { display: flex; justify-content: space-between; align-items: flex-start; }
.note-date { font-size: 11px; color: var(--text2); }
.note-title { font-size: 14px; font-weight: 500; color: var(--text); margin-top: 2px; }
.note-preview { font-size: 13px; color: var(--text2); margin-top: 4px; line-height: 1.5; }
.note-tag {
  display: inline-block; font-size: 10px; padding: 2px 8px;
  border-radius: 20px; margin-top: 7px; font-weight: 500;
}
.note-tag.practice { background: #faeeda; color: #854f0b; }
.note-tag.film { background: #e6f1fb; color: #185fa5; }
.note-tag.strategy { background: #e1f5ee; color: #0f6e56; }
.empty-state {
  text-align: center; padding: 2.5rem 1rem;
  color: var(--text2); font-size: 14px;
}
.empty-state i { font-size: 32px; display: block; margin-bottom: 8px; opacity: 0.4; }

.week-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; margin-bottom: 1.1rem; }
.day-chip {
  text-align: center; padding: 7px 2px; border-radius: 8px;
  border: 0.5px solid var(--border); background: var(--surface); cursor: pointer;
}
.day-chip .dl { font-size: 10px; color: var(--text2); }
.day-chip .dn { font-size: 15px; font-weight: 500; color: var(--text); }
.day-chip.active { background: var(--black); border-color: var(--black); }
.day-chip.active .dl, .day-chip.active .dn { color: var(--gold); }
.day-chip.has-workout { border-color: var(--gold-border); }

.progress-bar-wrap { background: var(--surface2); border-radius: 20px; height: 6px; overflow: hidden; margin: 6px 0 12px; }
.progress-bar { height: 6px; background: var(--gold); border-radius: 20px; transition: width 0.3s; }

.exercise-row {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 0; border-bottom: 0.5px solid var(--border); cursor: pointer;
}
.exercise-row:last-child { border-bottom: none; }
.ex-check {
  width: 22px; height: 22px; border-radius: 50%;
  border: 0.5px solid var(--border); flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 12px; color: transparent;
}
.ex-check.done { background: var(--gold); border-color: var(--gold); color: var(--black); }
.ex-name { flex: 1; font-size: 14px; color: var(--text); }
.ex-name.done { text-decoration: line-through; color: var(--text2); }
.ex-detail { font-size: 12px; color: var(--text2); }
.day-label-text { font-size: 15px; font-weight: 500; color: var(--text); margin-bottom: 3px; }
.day-prog-row { display: flex; justify-content: space-between; align-items: center; }

.plays-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 9px; margin-bottom: 1rem; }
.play-card {
  background: var(--surface); border: 0.5px solid var(--border);
  border-radius: 12px; padding: 0.9rem; cursor: pointer; transition: border-color 0.15s;
}
.play-card:hover { border-color: var(--gold-border); }
.play-diagram {
  width: 100%; height: 76px; background: var(--black);
  border-radius: 8px; margin-bottom: 8px;
  display: flex; align-items: center; justify-content: center; font-size: 24px;
  border: 0.5px solid #333;
}
.play-name { font-size: 13px; font-weight: 500; color: var(--text); }
.play-preview { font-size: 11px; color: var(--text2); margin-top: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.play-badge {
  display: inline-block; font-size: 10px; padding: 2px 7px;
  border-radius: 20px; margin-top: 6px; font-weight: 500;
}
.play-badge.run { background: #faeeda; color: #854f0b; }
.play-badge.pass { background: #e6f1fb; color: #185fa5; }
.play-badge.defense { background: #fcebeb; color: #a32d2d; }
.play-badge.special { background: #eeedfe; color: #534ab7; }

.canvas-wrap {
  background: var(--surface); border: 0.5px solid var(--border);
  border-radius: 12px; padding: 1rem; margin-bottom: 10px;
}
.canvas-wrap h3 { font-size: 13px; font-weight: 500; margin-bottom: 10px; color: var(--text); }
#playCanvas { width: 100%; height: 180px; border-radius: 8px; cursor: crosshair; touch-action: none; display: block; }
.canvas-tools { display: flex; gap: 7px; margin-top: 8px; flex-wrap: wrap; }
.tool-btn {
  padding: 5px 11px; border-radius: 8px;
  border: 0.5px solid var(--border); background: var(--surface2);
  font-size: 12px; color: var(--text2); cursor: pointer; display: flex; align-items: center; gap: 5px;
}
.tool-btn.active { background: var(--black); color: var(--gold); border-color: var(--black); }

.toast {
  position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%);
  background: var(--black); color: var(--gold); font-size: 12px;
  padding: 7px 16px; border-radius: 20px; border: 0.5px solid var(--gold-border);
  opacity: 0; transition: opacity 0.25s; pointer-events: none; white-space: nowrap; z-index: 100;
}
.toast.show { opacity: 1; }

.shared-note {
  font-size: 11px; color: var(--text2); text-align: center;
  margin-bottom: 8px; padding: 5px 10px; background: var(--surface2);
  border-radius: 8px; border: 0.5px solid var(--border);
}

.workout-box {
  background: var(--surface); border: 0.5px solid var(--border);
  border-radius: 12px; padding: 1rem;
}
</style>
</head>
<body>

<div id="app">
  <div class="header">
    <div class="header-crest">M</div>
    <div>
      <h1>Monarchs Playbook</h1>
      <p>Archbishop Mitty Football</p>
    </div>
    <div class="sync-dot" id="sync-dot" title="Storage sync status"></div>
  </div>

  <nav class="nav">
    <button class="active" onclick="switchTab('notes')">
      <i class="ti ti-notebook"></i> Notes
    </button>
    <button onclick="switchTab('workout')">
      <i class="ti ti-barbell"></i> Workouts
    </button>
    <button onclick="switchTab('plays')">
      <i class="ti ti-topology-star"></i> Plays
    </button>
  </nav>

  <!-- NOTES TAB -->
  <div id="tab-notes" class="tab active">
    <div class="shared-note">
      <i class="ti ti-cloud"></i> Notes sync across all your devices
    </div>
    <div class="section-header">
      <h2>Meeting notes</h2>
      <button class="btn-sm" onclick="toggleNoteForm()"><i class="ti ti-plus"></i> New note</button>
    </div>
    <div class="search-wrap">
      <i class="ti ti-search search-icon"></i>
      <input type="text" id="note-search" placeholder="Search notes..." oninput="renderNotes()">
    </div>
    <div id="note-form" class="add-form" style="display:none;">
      <h3>Add meeting note</h3>
      <div class="form-row"><label>Title</label><input type="text" id="note-title" placeholder="e.g. Pre-game walkthrough"></div>
      <div class="form-row"><label>Category</label>
        <select id="note-tag">
          <option value="practice">Practice</option>
          <option value="film">Film session</option>
          <option value="strategy">Strategy</option>
        </select>
      </div>
      <div class="form-row"><label>Notes</label><textarea id="note-content" placeholder="Write your notes here..."></textarea></div>
      <button class="btn-gold" onclick="saveNote()">Save note</button>
    </div>
    <div class="notes-list" id="notes-list"></div>
  </div>

  <!-- WORKOUT TAB -->
  <div id="tab-workout" class="tab">
    <div class="section-header"><h2>This week</h2></div>
    <div class="week-grid" id="week-grid"></div>
    <div id="workout-day-content"></div>
  </div>

  <!-- PLAYS TAB -->
  <div id="tab-plays" class="tab">
    <div class="shared-note">
      <i class="ti ti-cloud"></i> Plays sync across all your devices
    </div>
    <div class="section-header">
      <h2>Playbook</h2>
      <button class="btn-sm" onclick="togglePlayForm()"><i class="ti ti-plus"></i> Add play</button>
    </div>
    <div id="play-form" class="add-form" style="display:none;">
      <h3>New play</h3>
      <div class="form-row"><label>Play name</label><input type="text" id="play-name" placeholder="e.g. Trips Right Post"></div>
      <div class="form-row"><label>Type</label>
        <select id="play-type">
          <option value="run">Run</option>
          <option value="pass">Pass</option>
          <option value="defense">Defense</option>
          <option value="special">Special teams</option>
        </select>
      </div>
      <div class="form-row"><label>Assignments / notes</label><textarea id="play-notes" placeholder="Routes, blocks, reads..."></textarea></div>
      <div class="canvas-wrap">
        <h3>Draw the play</h3>
        <canvas id="playCanvas"></canvas>
        <div class="canvas-tools">
          <button class="tool-btn active" id="tool-line" onclick="setTool('line')"><i class="ti ti-pencil"></i> Route</button>
          <button class="tool-btn" id="tool-player" onclick="setTool('player')"><i class="ti ti-circle"></i> Player</button>
          <button class="tool-btn" id="tool-ball" onclick="setTool('ball')">🏈 Ball</button>
          <button class="tool-btn" onclick="clearCanvas()"><i class="ti ti-trash"></i> Clear</button>
        </div>
      </div>
      <button class="btn-gold" onclick="savePlay()">Save play</button>
    </div>
    <div class="plays-grid" id="plays-grid"></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  // ── State ──────────────────────────────────────────────────────────────────
  let notes = [];
  let plays = [];
  let workoutState = {};
  let selectedDay = new Date().getDay();
  let noteFormOpen = false;
  let playFormOpen = false;
  let currentTool = 'line';
  let drawing = false, lastX = 0, lastY = 0;
  let ctx = null;
  let canvasInitialized = false;

  // ── Storage keys ───────────────────────────────────────────────────────────
  const NOTES_KEY   = 'mitty_notes_v1';
  const PLAYS_KEY   = 'mitty_plays_v1';
  const WORKOUT_KEY = 'mitty_workout_v1';

  // ── Default workout plan ───────────────────────────────────────────────────
  const DEFAULT_WORKOUT = {
    1: { name: 'Upper body strength', exercises: [
      { name: 'Bench press',     detail: '4×6 @ 75%',       done: false },
      { name: 'Pull-ups',        detail: '3×10',             done: false },
      { name: 'Dumbbell rows',   detail: '3×12 each',        done: false },
      { name: 'Shoulder press',  detail: '3×10',             done: false }
    ]},
    3: { name: 'Speed & agility', exercises: [
      { name: '40-yard dash × 6', detail: 'Full rest between', done: false },
      { name: 'Ladder drills',    detail: '4 patterns × 3',   done: false },
      { name: '3-cone drill',     detail: '5 × full speed',   done: false },
      { name: 'Box jumps',        detail: '4×6',              done: false }
    ]},
    5: { name: 'Lower body strength', exercises: [
      { name: 'Squats',           detail: '4×6 @ 80%',   done: false },
      { name: 'Romanian deadlift',detail: '3×10',         done: false },
      { name: 'Single-leg press', detail: '3×12 each',   done: false },
      { name: 'Hip thrusts',      detail: '3×15',        done: false }
    ]},
    0: { name: 'Recovery & film', exercises: [
      { name: 'Foam roll + stretch', detail: '20 min',          done: false },
      { name: 'Film review',         detail: 'Watch last game', done: false },
      { name: 'Mental prep journal', detail: '10 min',          done: false }
    ]}
  };

  // ── Sync dot ───────────────────────────────────────────────────────────────
  function setSyncDot(state) {
    document.getElementById('sync-dot').className = 'sync-dot ' + state;
  }

  // ── Load all data from storage ─────────────────────────────────────────────
  async function loadAll() {
    setSyncDot('syncing');
    try {
      const [nr, pr, wr] = await Promise.all([
        window.storage.get(NOTES_KEY,   true).catch(() => null),
        window.storage.get(PLAYS_KEY,   true).catch(() => null),
        window.storage.get(WORKOUT_KEY, true).catch(() => null)
      ]);
      notes        = nr ? JSON.parse(nr.value) : [];
      plays        = pr ? JSON.parse(pr.value) : [];
      workoutState = wr ? JSON.parse(wr.value) : JSON.parse(JSON.stringify(DEFAULT_WORKOUT));
      setSyncDot('synced');
    } catch (e) {
      workoutState = JSON.parse(JSON.stringify(DEFAULT_WORKOUT));
      setSyncDot('error');
    }
    renderNotes();
    renderWeek();
    renderPlays();
  }

  // ── Persist helpers ────────────────────────────────────────────────────────
  async function saveNotes() {
    setSyncDot('syncing');
    try   { await window.storage.set(NOTES_KEY,   JSON.stringify(notes),        true); setSyncDot('synced'); }
    catch { setSyncDot('error'); }
  }
  async function savePlays() {
    setSyncDot('syncing');
    try   { await window.storage.set(PLAYS_KEY,   JSON.stringify(plays),        true); setSyncDot('synced'); }
    catch { setSyncDot('error'); }
  }
  async function saveWorkout() {
    setSyncDot('syncing');
    try   { await window.storage.set(WORKOUT_KEY, JSON.stringify(workoutState), true); setSyncDot('synced'); }
    catch { setSyncDot('error'); }
  }

  // ── Toast ──────────────────────────────────────────────────────────────────
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2200);
  }

  // ── Tab switching ──────────────────────────────────────────────────────────
  function switchTab(tab) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.nav button').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + tab).classList.add('active');
    ['notes', 'workout', 'plays'].forEach((t, i) => {
      if (t === tab) document.querySelectorAll('.nav button')[i].classList.add('active');
    });
    if (tab === 'plays' && playFormOpen) setTimeout(() => { if (!canvasInitialized) initCanvas(); }, 60);
  }

  // ── Notes ──────────────────────────────────────────────────────────────────
  function toggleNoteForm() {
    noteFormOpen = !noteFormOpen;
    document.getElementById('note-form').style.display = noteFormOpen ? 'block' : 'none';
    if (noteFormOpen) document.getElementById('note-title').focus();
  }

  function saveNote() {
    const title = document.getElementById('note-title').value.trim();
    if (!title) { showToast('Add a title first'); return; }
    const tag     = document.getElementById('note-tag').value;
    const content = document.getElementById('note-content').value.trim();
    const today   = new Date();
    notes.unshift({
      id: Date.now(), title, tag, content,
      date: today.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
    });
    document.getElementById('note-title').value   = '';
    document.getElementById('note-content').value = '';
    noteFormOpen = false;
    document.getElementById('note-form').style.display = 'none';
    saveNotes();
    renderNotes();
    showToast('Note saved');
  }

  function deleteNote(id, e) {
    e.stopPropagation();
    notes = notes.filter(n => n.id !== id);
    saveNotes();
    renderNotes();
  }

  function highlight(text, q) {
    if (!q) return text;
    const re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
    return text.replace(re, '<mark style="background:rgba(200,153,26,0.35);color:inherit;border-radius:2px;">$1</mark>');
  }

  function renderNotes() {
    const q        = (document.getElementById('note-search')?.value || '').toLowerCase();
    const filtered = notes.filter(n =>
      !q || n.title.toLowerCase().includes(q) || (n.content || '').toLowerCase().includes(q)
    );
    const list     = document.getElementById('notes-list');
    if (!filtered.length) {
      list.innerHTML = `<div class="empty-state"><i class="ti ti-notebook"></i>${q ? 'No notes match your search.' : 'No notes yet. Add your first one above.'}</div>`;
      return;
    }
    const tagLabel = { practice: 'Practice', film: 'Film session', strategy: 'Strategy' };
    list.innerHTML = filtered.map(n => `
      <div class="note-card ${n.tag}">
        <div class="note-card-top">
          <div>
            <div class="note-date">${n.date}</div>
            <div class="note-title">${highlight(n.title, q)}</div>
          </div>
          <button class="btn-icon" onclick="deleteNote(${n.id}, event)" aria-label="Delete note"><i class="ti ti-trash"></i></button>
        </div>
        ${n.content ? `<div class="note-preview">${highlight(n.content.slice(0, 120) + (n.content.length > 120 ? '…' : ''), q)}</div>` : ''}
        <span class="note-tag ${n.tag}">${tagLabel[n.tag]}</span>
      </div>
    `).join('');
  }

  // ── Workouts ───────────────────────────────────────────────────────────────
  function renderWeek() {
    const days = ['S','M','T','W','T','F','S'];
    const today = new Date();
    const startOfWeek = new Date(today);
    startOfWeek.setDate(today.getDate() - today.getDay());
    const grid = document.getElementById('week-grid');
    grid.innerHTML = days.map((d, i) => {
      const date = new Date(startOfWeek);
      date.setDate(startOfWeek.getDate() + i);
      const isActive   = i === selectedDay;
      const hasWorkout = workoutState[i] !== undefined;
      return `<div class="day-chip ${isActive ? 'active' : ''} ${hasWorkout && !isActive ? 'has-workout' : ''}" onclick="selectDay(${i})">
        <div class="dl">${d}</div>
        <div class="dn">${date.getDate()}</div>
      </div>`;
    }).join('');
    renderDayWorkout();
  }

  function selectDay(i) { selectedDay = i; renderWeek(); }

  function renderDayWorkout() {
    const content = document.getElementById('workout-day-content');
    const plan    = workoutState[selectedDay];
    if (!plan) {
      content.innerHTML = `<div class="empty-state"><i class="ti ti-moon"></i>Rest day — recovery is part of the game.</div>`;
      return;
    }
    const done = plan.exercises.filter(e => e.done).length;
    const pct  = Math.round((done / plan.exercises.length) * 100);
    content.innerHTML = `
      <div class="workout-box">
        <div class="day-prog-row">
          <span class="day-label-text">${plan.name}</span>
          <span style="font-size:12px;color:var(--text2);">${done}/${plan.exercises.length}</span>
        </div>
        <div class="progress-bar-wrap"><div class="progress-bar" style="width:${pct}%"></div></div>
        ${plan.exercises.map((ex, i) => `
          <div class="exercise-row" onclick="toggleExercise(${selectedDay}, ${i})">
            <div class="ex-check ${ex.done ? 'done' : ''}"><i class="ti ti-check"></i></div>
            <span class="ex-name ${ex.done ? 'done' : ''}">${ex.name}</span>
            <span class="ex-detail">${ex.detail}</span>
          </div>
        `).join('')}
      </div>
    `;
  }

  function toggleExercise(day, i) {
    workoutState[day].exercises[i].done = !workoutState[day].exercises[i].done;
    saveWorkout();
    renderDayWorkout();
  }

  // ── Plays ──────────────────────────────────────────────────────────────────
  function renderPlays() {
    const grid     = document.getElementById('plays-grid');
    const typeLabel = { run: 'Run', pass: 'Pass', defense: 'Defense', special: 'Special teams' };
    const emojiMap  = { run: '🏃', pass: '📐', defense: '🛡️', special: '⚡' };
    if (!plays.length) {
      grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1"><i class="ti ti-topology-star"></i>No plays yet. Draw your first one above.</div>`;
      return;
    }
    grid.innerHTML = plays.map(p => `
      <div class="play-card">
        <div class="play-diagram">${p.emoji || emojiMap[p.type] || '🏈'}</div>
        <div class="play-name">${p.name}</div>
        <div class="play-preview">${p.notes || ''}</div>
        <span class="play-badge ${p.type}">${typeLabel[p.type] || p.type}</span>
      </div>
    `).join('');
  }

  function togglePlayForm() {
    playFormOpen = !playFormOpen;
    document.getElementById('play-form').style.display = playFormOpen ? 'block' : 'none';
    if (playFormOpen) setTimeout(() => { if (!canvasInitialized) initCanvas(); }, 60);
  }

  function savePlay() {
    const name = document.getElementById('play-name').value.trim();
    if (!name) { showToast('Add a play name first'); return; }
    const type   = document.getElementById('play-type').value;
    const notes_ = document.getElementById('play-notes').value.trim();
    const emojiMap = { run: '🏃', pass: '📐', defense: '🛡️', special: '⚡' };
    plays.unshift({ id: Date.now(), name, type, emoji: emojiMap[type], notes: notes_ });
    document.getElementById('play-name').value  = '';
    document.getElementById('play-notes').value = '';
    canvasInitialized = false; ctx = null;
    clearCanvas();
    playFormOpen = false;
    document.getElementById('play-form').style.display = 'none';
    savePlays();
    renderPlays();
    showToast('Play saved');
  }

  // ── Canvas (play drawing) ──────────────────────────────────────────────────
  function initCanvas() {
    const canvas = document.getElementById('playCanvas');
    if (!canvas) return;
    canvasInitialized = true;
    canvas.width  = canvas.offsetWidth * window.devicePixelRatio;
    canvas.height = 180 * window.devicePixelRatio;
    ctx = canvas.getContext('2d');
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    drawField();

    canvas.onpointerdown = e => {
      drawing = true;
      const r = canvas.getBoundingClientRect();
      lastX = e.clientX - r.left; lastY = e.clientY - r.top;
      if (currentTool === 'player') drawDot(lastX, lastY, '#c8991a');
      if (currentTool === 'ball')   drawDot(lastX, lastY, '#e87722');
    };
    canvas.onpointermove = e => {
      if (!drawing || currentTool !== 'line') return;
      const r = canvas.getBoundingClientRect();
      const x = e.clientX - r.left, y = e.clientY - r.top;
      ctx.strokeStyle = '#f0c040'; ctx.lineWidth = 2.5; ctx.lineCap = 'round';
      ctx.beginPath(); ctx.moveTo(lastX, lastY); ctx.lineTo(x, y); ctx.stroke();
      lastX = x; lastY = y;
    };
    canvas.onpointerup = () => { drawing = false; };
  }

  function drawField() {
    if (!ctx) return;
    const w = document.getElementById('playCanvas').offsetWidth, h = 180;
    ctx.fillStyle = '#0d0d0d';
    ctx.fillRect(0, 0, w, h);
    ctx.strokeStyle = 'rgba(200,153,26,0.12)'; ctx.lineWidth = 1;
    for (let i = 1; i < 4; i++) {
      ctx.beginPath(); ctx.moveTo(0, h * i / 4); ctx.lineTo(w, h * i / 4); ctx.stroke();
    }
    ctx.strokeStyle = 'rgba(200,153,26,0.25)'; ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.moveTo(0, h / 2); ctx.lineTo(w, h / 2); ctx.stroke();
  }

  function drawDot(x, y, color) {
    if (!ctx) return;
    ctx.fillStyle = color; ctx.beginPath(); ctx.arc(x, y, 8, 0, Math.PI * 2); ctx.fill();
  }

  function clearCanvas() {
    canvasInitialized = false;
    const canvas = document.getElementById('playCanvas');
    if (!canvas) return;
    canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
    ctx = null;
    setTimeout(initCanvas, 30);
  }

  function setTool(t) {
    currentTool = t;
    document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('active'));
    const el = document.getElementById('tool-' + t);
    if (el) el.classList.add('active');
  }

  // ── Note: window.storage is provided by the Claude artifact runtime.
  // ── When running standalone, replace with a localStorage shim, e.g.:
  // ── window.storage = {
  // ──   get: (k) => Promise.resolve(localStorage.getItem(k) ? {value: localStorage.getItem(k)} : null),
  // ──   set: (k, v) => { localStorage.setItem(k, v); return Promise.resolve({value: v}); }
  // ── };

  loadAll();
</script>
</body>
